# Template for project-local SSH configuration
# Replace the <PLACEHOLDERS> with your actual IPs before using.
# IMPORTANT: Use the actual POD IPs (10.0.11.x or 10.0.12.x), NOT the ClusterIPs.

Host ms-bastion
    HostName 3.227.22.113  #bastion host public IP
    User ec2-user
    # Ensure this points to the correct location of your PEM file (requires strict file permissions!)
    IdentityFile ./anju.pem
    
    # -----------------------------------
    # Port Forwarding (Tunnels)
    # -----------------------------------
    
    # PostgreSQL Tunnel (Local 5432 -> Postgres Pod)
    LocalForward 5432 10.0.12.246:5432
    
    # Redis Tunnel (Local 6379 -> Redis Pod)
    LocalForward 6379 10.0.11.151:6379
    
    # Schema Registry Tunnel (Local 8080 -> Schema Registry Pod)
    LocalForward 8080 10.0.11.157:8080
    
    # Kafka Tunnels (The Multi-Broker Cluster)
    # Each broker is mapped to a unique local IP (127.0.0.1, 127.0.0.2, etc)
    # This allows all brokers to use port 9092, matching the Kafka metadata.
    LocalForward 127.0.0.1:9092 10.0.12.12:9092
    LocalForward 127.0.0.2:9092 10.0.11.120:9092
    LocalForward 127.0.0.3:9092 10.0.11.104:9092

